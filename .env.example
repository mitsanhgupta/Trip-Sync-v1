############################################
# Supabase configuration (frontend / Vite) #
############################################
# This app is Vite: use VITE_* (not Next.js NEXT_PUBLIC_*).

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# JWT "anon" "public" key from Dashboard → Settings → API (role = anon).
VITE_SUPABASE_ANON_KEY=""

# Optional: Dashboard publishable key (sb_publishable_...) if you omit anon above.
# VITE_SUPABASE_PUBLISHABLE_KEY=""

###################################
# Supabase configuration (server) #
###################################

# Server-side only – NEVER expose this to the browser or commit to Git.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Put your Supabase service role key here (do NOT use in client code)
SUPABASE_SERVICE_ROLE_KEY=""

# Optional: direct Postgres connection string (server only)
# SUPABASE_DB_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Optional: publishable key if needed on the server for other integrations
# SUPABASE_PUBLISHABLE_KEY=""

# Mapbox tokens:
# - VITE_MAPBOX_PUBLIC_TOKEN is safe for frontend map rendering (public token from Mapbox account).
# - MAPBOX_SECRET_TOKEN must stay server-side only (often same as default public token for dev; use a secret token in production).
VITE_MAPBOX_PUBLIC_TOKEN=""
MAPBOX_SECRET_TOKEN=""
